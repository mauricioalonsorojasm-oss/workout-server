generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Workout {
  id          String   @id @default(cuid())
  name        String
  duration    Int
  calories    Int?
  date        DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  exercises   Exercise[]
}

model Exercise {
  id          String   @id @default(cuid())
  name        String
  sets        Int
  reps        Int
  weight      Float?
  workoutId   String
  createdAt   DateTime @default(now())

  workout     Workout  @relation(fields: [workoutId], references: [id])
}